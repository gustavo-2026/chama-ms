# ===========================================
# CHAMA API - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# ============ APP SETTINGS ============
APP_NAME=Chama API
DEBUG=false

# ============ DATABASE ============
DATABASE_URL=postgresql://user:password@localhost:5432/chama

# ============ SECURITY (CRITICAL) ============
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-characters-long

# ============ MPESA (KENYA) ============
MPESA_ENV=sandbox  # or "production"
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/mpesa/callback

# ============ AFRICA'S TALKING (SMS) ============
AT_API_KEY=
AT_USERNAME=

# ============ REDIS (OPTIONAL) ============
REDIS_URL=redis://localhost:6379

# ============ EXTERNAL SERVICES ============
# Add webhook URLs, API keys for other services here
